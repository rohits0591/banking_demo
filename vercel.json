{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "FIREBASE_SERVICE_ACCOUNT_KEY": "@firebase_service_account_key",
    "FIREBASE_DATABASE_URL": "@firebase_database_url",
    "FIREBASE_STORAGE_BUCKET": "@firebase_storage_bucket",
    "NODE_ENV": "production"
  }
}
